# Token Airtable (Personal Access Token) avec les scopes :
#   data.records:read, data.records:write, schema.bases:read, schema.bases:write
# scope sur la base "Dour 2026".
AIRTABLE_TOKEN=pat...

# ID de la base "Dour 2026" (commence par app..., visible dans l'URL Airtable).
AIRTABLE_BASE_ID=app...

# (Optionnel) Webhook Discord du channel actus : recap quotidien (nouveaux artistes
# ou "rien de neuf"). Discord > Param. du serveur > Integrations > Webhooks > Nouveau.
DISCORD_WEBHOOK_URL=

